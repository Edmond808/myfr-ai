# Copy to .env.local and fill the 3 values below.
# Supabase keys: Dashboard → Project Settings → API

# 1. Anthropic — live AI dispatch (server-side only)
ANTHROPIC_API_KEY=

# 2. Supabase project URL — EU region recommended (Frankfurt or Paris)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# 3. Supabase anon / public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OAuth (Google, Apple): configure providers in Supabase Dashboard only —
# no extra app env vars. See docs/SUPABASE_AUTH.md for redirect URLs.

# Optional: service role for admin scripts only — never expose to client
# SUPABASE_SERVICE_ROLE_KEY=

# Phase 4 — Stripe Connect (not required yet)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
