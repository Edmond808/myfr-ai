# Copy to mobile/.env and fill values (same Supabase project as web).

# Web API base URL — must reach your Next.js dev server or production deploy
# iOS Simulator: http://localhost:3000
# Physical iPhone: http://YOUR_MAC_IP:3000 (e.g. http://192.168.1.42:3000)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Supabase (same keys as web .env.local)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
